{
  "name": "vendorhub/event-os-backend",
  "type": "project",
  "description": "Vendor Event OS (EventOS.id) - Laravel 12 REST API & Realtime Reverb Engine",
  "keywords": ["laravel", "saas", "event-management", "reverb", "minio", "meilisearch", "ai"],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "guzzlehttp/guzzle": "^7.8",
    "laravel/framework": "^12.0",
    "laravel/reverb": "^1.0",
    "laravel/sanctum": "^4.0",
    "laravel/scout": "^10.0",
    "laravel/tinker": "^2.9",
    "league/flysystem-aws-s3-v3": "^3.0",
    "meilisearch/meilisearch-php": "^1.6"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
