APP_NAME="Vendor Event OS API"
APP_ENV=production
APP_KEY=base64:7B5zIqmP3nZ2qW1zE4rT6yU8iO9pA0sD1fG2hJ3kL4m=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# 1. DATABASE CONNECTION (MySQL Best Practice)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vendor_event_os
DB_USERNAME=root
DB_PASSWORD=secret

# 2. CACHE, QUEUE & SESSION (Redis for High Concurrency)
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 3. LARAVEL REVERB REALTIME ENGINE WEBSOCKET
REVERB_APP_ID=vendoros_reverb_123
REVERB_APP_KEY=reverb_client_key_456
REVERB_APP_SECRET=reverb_secret_key_789
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# 4. STORAGE MINIO (S3 COMPATIBLE FOR CONTRACTS & LAYOUTS)
FILESYSTEM_DISK=minio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=vendor-os-assets
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# 5. SEARCH ENGINE MEILISEARCH (<50ms Sub-second Search)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterKey

# 6. INTEGRASI GENERATIVE AI (OpenAI API / OpenRouter)
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://openrouter.ai/api/v1
AI_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# 7. PAYMENT GATEWAY MIDTRANS & WHATSAPP API
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
WHATSAPP_API_TOKEN=EAAxxxxxxxxx
